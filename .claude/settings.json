{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/track-changes.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/self-review.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx shadcn@latest add *)",
      "Bash(npm install*)",
      "Bash(npx prisma *)",
      "Bash(docker-compose *)",
      "Bash(bash scripts/*)"
    ]
  }
}
