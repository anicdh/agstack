flowchart TD
    subgraph Planning["Planning Phase"]
        OH["/office-hours\n(Product Discovery)"]
        CEO["/plan-ceo-review\n(Business Validation)"]
        ENG["/plan-eng-review\n(Technical Feasibility)"]
        PO["/product-owner-review\n(Epic Classification)"]
    end

    OH --> CEO --> ENG --> PO

    PO --> ClassifyEpic{"Epic Type?"}

    ClassifyEpic -->|"technical\n(no UI)"| SprintDirect["/plan-sprint"]
    ClassifyEpic -->|"user-oriented\n(has UI)"| DesignPhase

    subgraph DesignPhase["Design Phase"]
        PD["agent-product-design\n(Interactive Mockups)"]
        DR["/plan-design-review\n(Design Approval)"]
    end

    PD --> DR
    DR -->|"Approved"| SprintDirect
    DR -->|"Needs Changes"| PD

    subgraph SprintPlanning["Sprint Planning"]
        SprintDirect --> AskDevs["Ask: Who is participating?\n(e.g., an, minh)"]
        AskDevs --> CalcCap["Capacity = N devs x 25-30 pts"]
        CalcCap --> AssignTasks["AI assigns tasks per dev\n(dependency, domain, balance)"]
        AssignTasks --> DevConfirm["All devs confirm assignments"]
        DevConfirm --> CreateBranch["Create sprint/sprint-XX\nfrom main"]
    end

    CreateBranch --> SprintExec

    subgraph SprintExec["Sprint Execution (Parallel Devs, Sequential Agents)"]
        direction TB

        subgraph DevA["Dev An (13 pts)"]
            direction TB
            A_API["agent-api\nTASK-021, TASK-022"]
            A_PR1["PR → sprint branch\n(/review by other dev)"]
            A_FE["agent-frontend\nTASK-025"]
            A_PR2["PR → sprint branch\n(/review by other dev)"]
            A_API --> A_PR1 --> A_FE --> A_PR2
        end

        subgraph DevB["Dev Minh (12 pts)"]
            direction TB
            B_API["agent-api\nTASK-023"]
            B_PR1["PR → sprint branch\n(/review by other dev)"]
            B_FE["agent-frontend\nTASK-026, TASK-027"]
            B_PR2["PR → sprint branch\n(/review by other dev)"]
            B_API --> B_PR1 --> B_FE --> B_PR2
        end
    end

    A_PR1 -.->|"notify + rebase"| B_FE
    B_PR1 -.->|"notify + rebase"| A_FE

    subgraph QAPhase["QA Phase (on sprint branch)"]
        direction TB
        QA["/qa\n(Full integration test)"]
        DESIGN_CHECK["/design-review\n(Compare vs Mockup)"]
        FIX{"QA Pass?"}
        HOTFIX["Fix on sprint branch\nRe-run QA"]
    end

    A_PR2 --> QA
    B_PR2 --> QA
    QA --> DESIGN_CHECK --> FIX
    FIX -->|"No"| HOTFIX --> QA
    FIX -->|"Yes"| MergeMain

    subgraph MergeToMain["Merge to Main (Manual)"]
        MergeMain["PR: sprint/sprint-XX → main\n(All devs approve)"]
        MainClean["main updated\nCI/CD builds from clean code"]
    end

    MergeMain --> MainClean

    subgraph SprintEnd["Sprint End"]
        RETRO_CHECK{"Issues detected?\n(carry-over, rejection,\nvelocity drop)"}
        RETRO["/retro\n(Retrospective)"]
        NEXT["Next /plan-sprint\n(Ask participants again)"]
    end

    MainClean --> RETRO_CHECK
    RETRO_CHECK -->|"Yes"| RETRO --> NEXT
    RETRO_CHECK -->|"No"| NEXT

    style Planning fill:#e8f4fd,stroke:#2196F3
    style DesignPhase fill:#fff3e0,stroke:#FF9800
    style SprintPlanning fill:#e8f5e9,stroke:#4CAF50
    style SprintExec fill:#f3e5f5,stroke:#9C27B0
    style DevA fill:#e1bee7,stroke:#8E24AA
    style DevB fill:#ce93d8,stroke:#7B1FA2
    style QAPhase fill:#fff9c4,stroke:#F9A825
    style MergeToMain fill:#c8e6c9,stroke:#2E7D32
    style SprintEnd fill:#e0f2f1,stroke:#009688
