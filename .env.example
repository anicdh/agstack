# Env vars depend on your stack profile from /tech-stack-consult.
# /setup adjusts this file based on your profile (nestjs-rust, nestjs-only, go-only, python-only).

# ===================
# Frontend (all profiles)
# ===================
VITE_API_URL=http://localhost:3000/api/v1
VITE_APP_ENV=development

# ===================
# API (NestJS profiles: nestjs-rust, nestjs-only)
# ===================
PORT=3000
NODE_ENV=development

# Database — must match POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB in docker-compose.yml
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/__PROJECT_NAME___dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# SMTP (for email jobs — all profiles)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
